# Copy to .env.local and fill in (never commit .env.local)

# Backend base URL (no trailing slash). Use EITHER name:
# VITE_API_BASE_URL=https://soil-repo-gcp-git-678290165816.europe-west1.run.app
# VITE_API_URL=https://soil-repo-gcp-git-678290165816.europe-west1.run.app

# Optional Bearer token (same as Postman Authorization: Bearer ...)
# VITE_API_TOKEN=

# Default device id for Readings → "Fetch from backend"
# VITE_API_DEVICE_ID=1

# Firebase Web API key (Postman CRM → /signin query param key=)
# VITE_FIREBASE_WEB_API_KEY=
